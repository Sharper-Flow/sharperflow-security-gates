{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Sharperflow org-wide Renovate preset. Repos extend via: { \"extends\": [\"github>Sharper-Flow/sharperflow-security-gates\"] }",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    "docker:pinDigests"
  ],
  "dependencyDashboard": true,
  "semanticCommits": "auto",
  "schedule": ["before 6am on monday"],
  "minimumReleaseAge": "7 days",
  "internalChecksFilter": "strict",
  "automerge": true,
  "platformAutomerge": true,
  "labels": ["dependencies"],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on monday"]
  },
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"],
    "minimumReleaseAge": "0 days"
  },
  "packageRules": [
    {
      "description": "Cooldown cannot be validated for PM-driven update types",
      "matchUpdateTypes": ["lockFileMaintenance", "pin", "replacement"],
      "minimumReleaseAge": null
    },
    {
      "description": "Group non-major dev dependencies",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "dev dependencies (non-major)"
    }
  ]
}
